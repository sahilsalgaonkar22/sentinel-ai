# Frontend environment variables for Docker / Production build
# When running behind nginx proxy, API calls go through the same origin.
# For standalone deployment, set VITE_API_URL to your backend URL.
#
# Behind nginx (default):  leave VITE_API_URL empty → same-origin requests
# Standalone:              VITE_API_URL=https://api.yourdomain.com
VITE_API_URL=
VITE_WS_URL=
VITE_APP_NAME=SENTINEL AI
VITE_APP_VERSION=5.0.0
