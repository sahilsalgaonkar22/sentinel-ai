# ═══════════════════════════════════════════════════════════════════════════════
# SENTINEL AI — Environment Variable Template
# ═══════════════════════════════════════════════════════════════════════════════
#
# ⛔ THIS IS A TEMPLATE FILE — NEVER put real secrets here
# ⛔ NEVER commit .env to git — .gitignore already excludes it
#
# SETUP:
#   1. cp .env.example .env
#   2. Replace every REPLACE_WITH_* value with a real secret
#   3. python scripts/check_env.py       ← verify before starting
#   4. docker compose up -d              ← or run.py for local
#
# GENERATE SECRETS:
#   JWT_SECRET:          openssl rand -hex 32   (→ 64 chars)
#   SECRET_KEY:          openssl rand -hex 32   (→ 64 chars)
#   POSTGRES_PASSWORD:   openssl rand -hex 16   (→ 32 chars)
#   REDIS_PASSWORD:      openssl rand -hex 16   (→ 32 chars)
#   KAFKA_SASL_PASSWORD: openssl rand -hex 16   (→ 32 chars)
#   S3_SECRET_KEY:       openssl rand -hex 24   (→ 48 chars)
#
# OR auto-generate everything:
#   python scripts/check_env.py --generate
#
# ═══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=SENTINEL AI
APP_VERSION=5.0.0
DEBUG=False
SENTINEL_EXECUTION_MODE=local
SENTINEL_LOAD_DOTENV=true

# ── Auth Secrets (REQUIRED — 256-bit minimum) ─────────────────────────────────
# Must be ≥64 chars. Generate: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX_SECRET
JWT_ALGORITHM=HS256
SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_SECRET

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# IMPORTANT: Password in DATABASE_URL MUST match POSTGRES_PASSWORD exactly
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
POSTGRES_DB=sentinel
DATABASE_URL=postgresql+asyncpg://sentinel:REPLACE_WITH_SECURE_PASSWORD@localhost:5432/sentinel

# ── Redis ─────────────────────────────────────────────────────────────────────
# IMPORTANT: Password in REDIS_URL MUST match REDIS_PASSWORD exactly
REDIS_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
REDIS_URL=redis://:REPLACE_WITH_SECURE_PASSWORD@localhost:6379/0

# ── Kafka ─────────────────────────────────────────────────────────────────────
# For local dev: PLAINTEXT without SASL (no credentials needed)
# For production: use SASL_PLAINTEXT and configure credentials
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_SECURITY_PROTOCOL=PLAINTEXT

# ── CORS (REQUIRED — no wildcard allowed) ────────────────────────────────────
# Comma-separated list of frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# ── MinIO / S3 ────────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=REPLACE_WITH_MINIO_ACCESS_KEY
S3_SECRET_KEY=REPLACE_WITH_MINIO_SECRET_KEY
S3_BUCKET=sentinel-reports

# ── Elasticsearch (optional — enhanced search/analytics) ─────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ── LLM / AI ─────────────────────────────────────────────────────────────────
# Supported providers: gemini, openai
# Leave LLM_API_KEY empty to disable AI features (risk scoring uses rules-based fallback)
LLM_API_KEY=
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# ── SMTP Email Alerts (optional) ─────────────────────────────────────────────
SENTINEL_SMTP_HOST=smtp.gmail.com
SENTINEL_SMTP_PORT=587
SENTINEL_SMTP_USER=your-email@gmail.com
SENTINEL_SMTP_PASSWORD=REPLACE_WITH_APP_PASSWORD
SENTINEL_SMTP_FROM=your-email@gmail.com
SENTINEL_SMTP_TLS=true

# ── Slack Alerts (optional) ──────────────────────────────────────────────────
SENTINEL_SLACK_WEBHOOK=

# ── Observability — Sentry (optional) ────────────────────────────────────────
SENTRY_DSN=

# ── Observability — OpenTelemetry / Jaeger (optional) ────────────────────────
OTEL_SERVICE_NAME=sentinel-gateway
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_TRACES_EXPORTER=otlp

# ── Scan Settings ─────────────────────────────────────────────────────────────
SCAN_TIMEOUT_SECONDS=300
BACKGROUND_SCANS=True

# ── Alerting Retry Config ─────────────────────────────────────────────────────
SENTINEL_ALERT_MAX_RETRIES=5
SENTINEL_ALERT_BACKOFF_BASE=2

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REDIS_ENABLED=true
RATE_LIMIT_FALLBACK_MEMORY=true

# ── DLQ Replay Worker ─────────────────────────────────────────────────────────
DLQ_RETRY_INTERVAL_SECONDS=60
DLQ_MAX_RETRIES=10

# ── Fail-Open / Degraded Mode Flags ──────────────────────────────────────────
ALLOW_REDIS_FAIL_OPEN=true
ALLOW_KAFKA_FAIL_OPEN=true
