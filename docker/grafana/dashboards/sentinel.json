{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "piechart", "name": "Pie chart", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "SENTINEL AI — Security Operations Center Observability Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active Scans",
      "description": "Number of scans currently running",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sentinel_active_scans",
          "instant": true,
          "legendFormat": "Active"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Scans Completed (24h)",
      "description": "Total scans completed in the last 24 hours",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "increase(sentinel_scans_total{status=\"completed\"}[24h])",
          "legendFormat": "Completed"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Scans Failed (24h)",
      "description": "Total scans that failed in the last 24 hours",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "increase(sentinel_scans_total{status=\"failed\"}[24h])",
          "legendFormat": "Failed"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Critical Findings (24h)",
      "description": "Critical severity findings discovered in last 24h",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "increase(sentinel_findings_total{severity=\"critical\"}[24h])",
          "legendFormat": "Critical"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Kafka Messages (1h)",
      "description": "Total Kafka messages produced in the last hour",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": null }]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "increase(sentinel_kafka_messages_total[1h])",
          "legendFormat": "Messages"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "HTTP Req Rate",
      "description": "Current API request rate (req/s)",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          },
          "unit": "reqps"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(http_requests_total[1m]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Scan Rate Over Time",
      "description": "Scans started vs completed per minute",
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        }
      },
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(sentinel_scans_total{status=\"started\"}[5m])",
          "legendFormat": "Started"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(sentinel_scans_total{status=\"completed\"}[5m])",
          "legendFormat": "Completed"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(sentinel_scans_total{status=\"failed\"}[5m])",
          "legendFormat": "Failed"
        }
      ]
    },
    {
      "id": 8,
      "type": "piechart",
      "title": "Findings by Severity",
      "description": "Distribution of all findings by severity level",
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "critical" }, "properties": [{ "id": "color", "value": { "fixedColor": "#dc2626", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "high" }, "properties": [{ "id": "color", "value": { "fixedColor": "#f97316", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "medium" }, "properties": [{ "id": "color", "value": { "fixedColor": "#f59e0b", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "low" }, "properties": [{ "id": "color", "value": { "fixedColor": "#3b82f6", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "info" }, "properties": [{ "id": "color", "value": { "fixedColor": "#64748b", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right" },
        "pieType": "donut"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (severity) (sentinel_findings_total)",
          "legendFormat": "{{severity}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Kafka Throughput by Topic",
      "description": "Messages produced per second per Kafka topic",
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "unit": "short"
        }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(sentinel_kafka_messages_total[5m])",
          "legendFormat": "{{topic}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "API Response Time (p95)",
      "description": "95th percentile HTTP response latency",
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "s"
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, handler))",
          "legendFormat": "p95 {{handler}}"
        }
      ]
    },
    {
      "id": 11,
      "type": "gauge",
      "title": "Scan Duration (avg seconds)",
      "description": "Average time to complete a full scan pipeline",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 180 },
              { "color": "red", "value": 600 }
            ]
          },
          "unit": "s",
          "min": 0,
          "max": 1800
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(sentinel_scan_duration_seconds_sum[1h]) / rate(sentinel_scan_duration_seconds_count[1h])",
          "legendFormat": "Avg Duration"
        }
      ]
    },
    {
      "id": 12,
      "type": "table",
      "title": "Findings by Tool",
      "description": "Total findings grouped by scanning tool",
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 20 },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "options": {
        "sortBy": [{ "displayName": "Value", "desc": true }]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (tool_name, severity) (sentinel_findings_total)",
          "legendFormat": "{{tool_name}} / {{severity}}",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "renameByName": { "tool_name": "Tool", "severity": "Severity", "Value": "Count" } } }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 37,
  "style": "dark",
  "tags": ["sentinel", "security", "soc"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "SENTINEL AI — SOC Dashboard",
  "uid": "sentinel-soc-v1",
  "version": 1
}
